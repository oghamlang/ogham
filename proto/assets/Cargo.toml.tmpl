[package]
name = "ogham-proto"
description = "Ogham schema language IR and plugin protocol — generated protobuf types"
version = "0.1.0"
edition = "2021"
license = "Apache-2.0"
repository = "https://github.com/oghamlang/ogham"
homepage = "https://github.com/oghamlang/ogham"
authors = ["Ogham Contributors"]
rust-version = "1.75"
keywords = ["ogham", "schema", "protobuf", "grpc", "ir"]
categories = ["encoding", "network-programming"]

[dependencies]
prost = { version = "0.14", features = ["derive"] }
tonic = { version = "0.14", features = ["transport"] }
tonic-prost = "0.14"
serde = { version = "1.0.219", features = ["serde_derive"] }
pbjson = "0.9"
pbjson-types = "0.9"

[features]
default = ["proto_full"]
## @@protoc_deletion_point(features)
## @@protoc_insertion_point(features)
