package store;

import github.com/oghamlang/std/uuid;
import github.com/oghamlang/std/time;
import github.com/oghamlang/std/validate;

// Common shapes reused across all store models.

shape Identifiable {
    uuid.UUID id;
}

shape Timestamps {
    time.Timestamp created_at;
    time.Timestamp updated_at;
}

shape SoftDelete {
    time.Timestamp? deleted_at;
}

shape Auditable {
    Identifiable;
    Timestamps;
}
